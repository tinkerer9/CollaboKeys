{
  "dependencies": {
    "socket.io": "^4.8.3",
    "winston": "^3.19.0"
  },
  "os": [
    "darwin"
  ],
  "name": "collaborativekeys",
  "version": "3.0.0",
  "description": "a collaborative keyboard game",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run compile && electron-builder",
    "test": "node src/server.js",
    "compile": "clang src/emulate/helper.c -framework ApplicationServices -arch arm64 -arch x86_64 -O3 -o src/emulate/helper"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinkerer9/collaborativekeys.git"
  },
  "keywords": [
    "collabokeys",
    "keyboard",
    "server",
    "game",
    "socketio",
    "nodejs",
    "emulate",
    "collaborate"
  ],
  "author": "Max Parisi <makermax101@gmail.com> (https://github.com/tinkerer9)",
  "contributors": [
    "@LethalShadowFlame (https://github.com/LethalShadowFlame)"
  ],
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/tinkerer9/collaborativekeys/issues",
    "email": "makermax101@gmail.com"
  },
  "homepage": "https://github.com/tinkerer9/collaborativekeys#readme",
  "build": {
    "appId": "com.collabokeys.app",
    "productName": "CollaboKeys",
    "mac": {
      "icon": "images/icon.icns",
      "target": "dmg",
      "category": "public.app-category.utilities",
      "identity": null
    },
    "extraResources": [
      {
        "from": "src/emulate/helper",
        "to": "helper"
      }
    ]
  }
}
