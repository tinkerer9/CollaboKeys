{
    "adminPage": {
        "enabled": true,
        "password": "hackathon2026",
        "autoAuthHost": true
    },
    "app": {
        "preventDisplaySleep": true,
        "splashScreenTime": 1000,
        "blankKeypressAtStart": true,
        "enableDevTools": false
    },
    "console": {
        "enabled": true
    },
    "logs": {
        "logPage": {
            "enabled": true
        },
        "logFileTypes": [
            "combined",
            "error",
            "warn"
        ],
        "deleteAtStart": false
    },
    "player": {
        "name": {
            "minLength": 3,
            "maxLength": 20,
            "regex": "[a-zA-Z0-9]"
        },
        "waitRoomWhenJoined": false,
        "maxReservedKeys": 0
    },
    "server": {
        "ports": [3000, 8080, 8000, 5000, 2000, 4000, 6000, 7000, 9000],
        "restrictToLocalhost": false
    },
    "allowEmulationAtStart": true,
    "autoAssignUnreservedKeys": true
}